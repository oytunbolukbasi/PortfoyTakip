# Database Configuration
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Railway Configuration
PGDATABASE="neondb"
PGHOST="host"
PGUSER="user"
PGPASSWORD="password"
PGPORT="5432"

# Application Configuration
NODE_ENV="development"
PORT="5000"
SESSION_SECRET="your-secret-key-here"

# Build Configuration
NIXPACKS_DEBIAN="1"